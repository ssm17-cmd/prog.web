let numeroAleatorio = Math.random() * 50;
let numeroInteiro = Math.floor(numeroAleatorio);
let numeroSecreto = numeroInteiro + 1;
let palpite;

do {
  palpite = prompt("Digite um número de 1 a 50:");
  palpite = parseInt(palpite);

  if (palpite < numeroSecreto) {
    alert("maior");
  } else if (palpite > numeroSecreto) {
    alert("menor");
  } else {
    alert("Parabéns! Você acertou.");
  }
} while (palpite != numeroSecreto);
